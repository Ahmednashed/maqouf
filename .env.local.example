# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ملقوف

# Optional: Resend for emails
RESEND_API_KEY=re_xxxxx

# ── AI Core (OpenAI) — ALL server-side only, never NEXT_PUBLIC_ ──────────────
# Required for the AI Assistant. Get a key at https://platform.openai.com
OPENAI_API_KEY=
# Optional overrides (documented defaults shown)
OPENAI_MODEL=gpt-4o-mini
AI_MAX_OUTPUT_TOKENS=700
AI_MAX_TOOL_ROUNDS=3
AI_DAILY_REQUEST_LIMIT_PER_USER=50
# When true, a provider outage falls back to the local rule engine
# (answers are clearly labeled as simplified, never presented as AI)
AI_MOCK_FALLBACK=false
# AI Agent v2 limits (optional, defaults shown)
AI_MAX_HISTORY_MESSAGES=12
AI_MAX_SOURCES=5
AI_MAX_SUGGESTED_ACTIONS=4
AI_MAX_STORED_MESSAGE_CHARS=6000
AI_MAX_TOOL_RESULT_CHARS=8000
# AI Brain v3 (optional)
# Stronger model for executive analysis (falls back to OPENAI_MODEL)
OPENAI_REASONING_MODEL=
AI_ENABLE_PLANNER=true
AI_PLANNER_MAX_OUTPUT_TOKENS=300
AI_MIN_CONFIDENCE_FOR_ENTITY_REUSE=0.8
